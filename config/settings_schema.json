[
  {
    "name": "theme_info",
    "theme_name": "help",
    "theme_label": "t:schema.theme_label",
    "theme_description": "t:schema.theme_description",
    "theme_version": "2.1.2",
    "theme_syntax_version": "v2",
    "theme_scope": "wiki",
    "theme_author": "Baklib",
    "theme_documentation_url": "https://help.baklib.cn/themes/docs",
    "theme_support_url": "https://help.baklib.cn/themes/docs/settings",
    "theme_thumb_url": "images/theme/${lang}/thumb.png",
    "theme_preview_images": [
      "images/theme/${lang}/index.png",
      "images/theme/${lang}/index-help-center.png",
      "images/theme/${lang}/index-faqs.png",
      "images/theme/${lang}/index-card.png",
      "images/theme/${lang}/index-support.png",
      "images/theme/${lang}/page.png"
    ],
    "theme_languages": [
      {
        "name": "中文简体",
        "value": "zh-CN"
      },
      {
        "name": "中文繁體",
        "value": "zh-TW"
      },
      {
        "name": "한국어",
        "value": "ko"
      },
      {
        "name": "English",
        "value": "en"
      },
      {
        "name": "日本語",
        "value": "ja"
      },
      {
        "name": "Deutsch",
        "value": "de"
      },
      {
        "name": "Français",
        "value": "fr"
      }
    ],
    "recommendations": {
      "color_schemas": {
        "fashion": {
          "name": "t:schema.recommendations.fashion.name",
          "colors": {
            "--theme-color-primary": "#03A9F4",
            "--theme-color-secondary": "#E91E63",
            "--theme-color-accent": "#AAAAAA",
            "--theme-color-info": "#2196F3",
            "--theme-color-success": "#4CAF50",
            "--theme-color-warning": "#FFC107"
          }
        },
        "old_school": {
          "name": "t:schema.recommendations.old_school.name",
          "colors": {
            "--theme-color-primary": "#9C27B0",
            "--theme-color-secondary": "#673AB7",
            "--theme-color-accent": "#AAAAAA",
            "--theme-color-info": "#418CC8",
            "--theme-color-success": "#29B52F",
            "--theme-color-warning": "#FFC107"
          }
        }
      }
    },
    "miniprogram": true
  },
  {
    "name": "t:schema.generic.name",
    "settings": [
      {
        "id": "logo_url",
        "type": "image_picker",
        "ratio": "3:1",
        "width": 240,
        "label": "t:schema.generic.settings.logo_url.label",
        "info": "t:schema.generic.settings.logo_url.info"
      },
      {
        "id": "company_name",
        "label": "t:schema.generic.settings.company_name.label",
        "type": "text",
        "default": "t:schema.generic.settings.company_name.default",
        "info": "t:schema.generic.settings.company_name.info"
      },
      {
        "id": "copyright_info",
        "type": "text",
        "label": "t:schema.generic.settings.copyright_info.label",
        "default": "t:schema.generic.settings.copyright_info.default"
      },
      {
        "id": "screen_width",
        "type": "radio",
        "label": "t:schema.generic.settings.screen_width.label",
        "choices": [
          { "label": "t:schema.generic.settings.screen_width.choices.narrow", "value":"1024px" },
          { "label": "t:schema.generic.settings.screen_width.choices.medium", "value":"1280px" },
          { "label": "t:schema.generic.settings.screen_width.choices.wide", "value":"1536px" },
          { "label": "t:schema.generic.settings.screen_width.choices.full", "value":"100%" }
        ],
        "default": "1280px"
      },
      {
        "id": "left_sidebar_width",
        "type": "range",
        "label": "t:schema.generic.settings.left_sidebar_width.label",
        "min": 200,
        "max": 600,
        "step": 1,
        "default": 240,
        "info": "t:schema.generic.settings.left_sidebar_width.info"
      },
      {
        "id": "right_sidebar_width",
        "type": "range",
        "label": "t:schema.generic.settings.right_sidebar_width.label",
        "min": 200,
        "max": 1200,
        "step": 1,
        "default": 240,
        "info": "t:schema.generic.settings.right_sidebar_width.info"
      },
      {
        "id": "header_type",
        "type": "radio",
        "label": "t:schema.generic.settings.header_type.label",
        "choices": [
          { "label": "t:schema.generic.settings.header_type.choices.transparent", "value": "0" },
          { "label": "t:schema.generic.settings.header_type.choices.custom", "value": "1" }
        ],
        "default": "1",
        "info": "t:schema.generic.settings.header_type.info"
      },
      {
        "id": "header_bg_color",
        "type": "color",
        "label": "t:schema.generic.settings.header_bg_color.label",
        "info": "",
        "default": "#ffffff"
      },
      {
        "id": "header_text_color",
        "type": "color",
        "label": "t:schema.generic.settings.header_text_color.label",
        "default": "#000000"
      },
      {
        "id": "show_published_at",
        "type": "checkbox",
        "label": "t:schema.generic.settings.show_published_at.label",
        "default": false
      },
      {
        "id": "show_author",
        "type": "checkbox",
        "label": "t:schema.generic.settings.show_author.label",
        "default": false
      },
      {
        "id": "show_card_icon",
        "type": "checkbox",
        "label": "t:schema.generic.settings.show_card_icon.label",
        "info": "t:schema.generic.settings.show_card_icon.info",
        "default": true
      },
      {
        "id": "ai_search_completed_text",
        "type": "text",
        "label": "t:schema.generic.settings.ai_search_completed_text.label",
        "info": "t:schema.generic.settings.ai_search_completed_text.info"
      }
    ]
  },
  {
    "name": "t:schema.page_config.name",
    "settings": [
      {
        "id": "show_page_tools_dropdown",
        "type": "checkbox",
        "label": "t:schema.page_config.settings.show_page_tools_dropdown.label",
        "default": true
      }
    ]
  },
  {
    "name": "t:schema.settings.weixin_share.title",
