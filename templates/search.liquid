{% assign index_page = site.pages[site.index_path] %}
{% assign search_placeholder = 'templates.search.placeholder' | t %}
{% assign empty_message = 'templates.search.no_results' | t %}
{% assign search_hot_tags = index_page.settings.search_hot_tags %}
{% assign hot_keywords = index_page.settings.search_hot_keywords | reg_split: "/\n/" %}

<div class="relative min-h-[60vh] bg-base-100 dark:bg-base-100">
  <div class="mx-auto max-w-7xl bg-base-100 px-4 pb-16 pt-8 md:pt-12 dark:bg-base-100" data-controller="link-target">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(240px,300px)] lg:items-start lg:gap-10 xl:gap-12">
      <main class="min-w-0 bg-base-100 dark:bg-base-100">
        <header class="pt-2">
          <div class="w-full max-w-3xl">
            {% form_tag 'search', class: 'w-full', data-turbo-frame: 'frame--search-results', data-turbo-action: 'advance' %}
              <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-base-content/50">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                </span>
                <input
                  type="search"
                  autofocus
                  name="{{ form.keywords_field_name }}"
                  value="{{ search.keywords | escape_once }}"
                  placeholder="{{ search_placeholder }}"
                  autocomplete="off"
                  class="block w-full rounded-lg border-2 border-primary/40 bg-base-100 py-3 pl-10 pr-4 text-base text-base-content shadow-sm outline-none transition placeholder:text-base-content/50 focus:border-primary focus:ring-2 focus:ring-primary/25 dark:border-primary/50 dark:bg-base-300 dark:text-base-content dark:placeholder:text-base-content/60"
                >
              </div>
            {% endform_tag %}

            <div class="mt-4 space-y-2 text-sm">
              {% if search_hot_tags.size > 0 %}
                <div class="text-base-content/70 dark:text-base-content/50">
                  <span class="mr-2 font-medium">{{ 'layout.theme.search_tags_label' | t }}:</span>
                  {% for tag in search_hot_tags %}
                    <a href="{{ tag.path }}" data-turbo-frame="_top" class="mr-2 inline-block text-primary hover:underline">
                      {{ tag.name }}
                    </a>
                  {% endfor %}
                </div>
              {% endif %}

              {% if hot_keywords.size > 0 %}
                <div class="text-base-content/70 dark:text-base-content/50">
                  <span class="mr-2 font-medium">{{ 'layout.theme.search_keywords_label' | t }}:</span>
                  {% for hot_keyword in hot_keywords %}
                    <a href="{{ site.index_path }}-/search?q={{ hot_keyword }}" class="mr-2 text-primary hover:underline">
                      {{ hot_keyword }}
                    </a>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </div>
        </header>

        <turbo-frame id="frame--search-results" class="mt-8 block">
          {% if search.tag %}
            <div class="mb-4">
              <span class="rounded px-2 py-1 text-sm text-base-content" style="background-color: {{ search.tag.color }}">
                {{ search.tag.name }}
              </span>
            </div>
          {% endif %}

          {% if search.keywords or search.tag %}
            {% paginate_tag search.pages, as: 'items', per: 20 %}
              {% assign extends_size = search.extends | size %}
              {% assign items_size = items | size %}
              {% assign total_size = extends_size | plus: items_size %}
              {% assign show_extends = search.page_number == 1 %}

              {% if total_size > 0 %}
                {% render 'support_search_list', items: items, extends: search.extends, show_extends: show_extends %}
                {% render 'support_paginate', paginate: paginate, turbo_frame: 'frame--search-results' %}
                <script>
                  (function () {
                    setTimeout(function () {
                      var container = document.getElementById('js--ai-search-container');
                      var aiSearch = document.getElementById('js--ai-search');
                      if (container && aiSearch) {
                        container.classList.remove('hidden');
                        aiSearch.dataset.aiSearchMessageValue = "{{ search.keywords | escape_once }}";
                      } else if (container) {
                        container.classList.add('hidden');
                      }
                    }, 10);
                  })();
                </script>
              {% else %}
                <div class="py-8">
                  {% render 'empty', message: empty_message %}
                </div>
                <script>
                  (function () {
                    setTimeout(function () {
                      var container = document.getElementById('js--ai-search-container');
                      if (container) container.classList.add('hidden');
                    }, 10);
                  })();
                </script>
              {% endif %}
            {% endpaginate_tag %}
          {% else %}
            <div class="py-8">
              {% render 'empty', message: empty_message %}
            </div>
          {% endif %}
        </turbo-frame>
      </main>

      <aside
        class="min-w-0 lg:sticky lg:top-4 lg:z-10 lg:max-h-[calc(100vh-2rem)] lg:overflow-y-auto lg:self-start"
      >
        {% if site.ai_search_enabled? %}
          {% render 'support_ai_search', keywords: search.keywords %}
        {% endif %}
      </aside>
    </div>
  </div>
</div>
