{% assign tag_pages = tag.pages %}
{% assign tag_pages_size = tag_pages | size %}

<div class="relative min-h-[60vh] bg-base-100 dark:bg-base-100">
  <div class="mx-auto max-w-7xl bg-base-100 px-4 pb-16 pt-8 md:pt-12 dark:bg-base-100" data-controller="link-target">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(240px,300px)] lg:items-start lg:gap-10 xl:gap-12">
      <main class="min-w-0 bg-base-100 dark:bg-base-100">
        <header class="pt-2">
          <h1 class="text-2xl font-semibold tracking-tight text-base-content md:text-3xl lg:text-4xl">
            # {{ tag.name }}
          </h1>
        </header>

        {% if tag_pages_size > 0 %}
          <section class="mt-8">
            {% render 'support_article_list', collection: tag.pages, per_page: 12 %}
          </section>
        {% else %}
          <section class="mt-8">
            {% assign message = 'templates.search.no_results' | t %}
            {% render 'empty', message: message %}
          </section>
        {% endif %}
      </main>

      <aside
        class="min-w-0 lg:sticky lg:top-4 lg:z-10 lg:max-h-[calc(100vh-2rem)] lg:overflow-y-auto lg:self-start"
      >
          <div class="rounded-xl border border-base-300 bg-base-200 p-6 shadow-sm dark:border-base-300 dark:bg-base-300/95">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-base-content/80 dark:text-base-content/70">
              {{ 'snippets.aside_nav.tags_title' | t }}
            </h2>
            <div class="mt-4 flex flex-wrap gap-2" aria-label="{{ 'snippets.aside_nav.tags_title' | t }}">
              {% for cloud_tag in site.tags %}
                {% if cloud_tag.path == tag.path %}
                  <span
                    class="rounded border border-primary bg-primary px-1 py-0.5 text-xs text-primary-content"
                    aria-current="page"
                  >
                    # {{ cloud_tag.name }}
                  </span>
                {% else %}
                  {% render 'tag', tag: cloud_tag %}
                {% endif %}
              {% endfor %}
            </div>
          </div>

      </aside>
    </div>
  </div>
</div>
