<div
  class="join shrink-0 rounded-md border border-base-300 bg-base-100"
  data-controller="copy-page page-tools"
  data-copy-page-copying-text-value="{{ "templates.page.llm_copying"  | t: '复制中...'  }}"
  data-copy-page-success-text-value="{{ 'templates.page.llm_copied' | t: '已复制' }}"
  data-copy-page-markdown-url-value="{{ page.markdown_url }}"
  data-page-tools-markdown-url-value="{{ page.markdown_url }}"
  data-page-tools-llm-prompt-value="{{ 'templates.page.llm_prompt_template' | t, url: page.markdown_url }}"
  data-page-tools-mcp-url-value="{{ site.mcp_url }}"
>
  <button type="button" class="btn btn-ghost btn-sm join-item border-0 bg-transparent hover:bg-base-200 px-4"
    data-action="copy-page#copyPage">
    <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2">
      <rect x="9" y="9" width="13" height="13" rx="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <span data-copy-page-target="buttonLabel">{{ 'snippets.page_tools.copy_page_label' | t }}</span>
  </button>
  <div class="dropdown dropdown-end join-item">
    <div tabindex="0" role="button"
      class="btn btn-ghost btn-sm rounded-none border-0 border-l border-base-300 bg-transparent px-3 hover:bg-base-200">
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6"></path>
      </svg>
    </div>
    <ul tabindex="-1"
      class="dropdown-content menu bg-base-100 rounded-box z-10 mt-2 min-w-80 p-2 shadow-sm border border-base-300">
      <li>
        <button type="button" class="group flex items-start gap-2.5 rounded-xl p-2 text-left"
          data-action="copy-page#copyPage">
          <span
            class="flex size-9 shrink-0 items-center justify-center rounded-xl border border-base-300 bg-base-100 text-base-content/50 transition-colors group-hover:text-base-content/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </span>
          <span class="flex min-w-0 flex-1 flex-col">
            <span class="font-semibold leading-tight">{{ 'snippets.page_tools.copy_page_label' | t }}</span>
            <span class="mt-0.5 text-xs text-base-content/60 leading-tight">{{ 'snippets.page_tools.copy_page_description' | t }}</span>
          </span>
        </button>
      </li>
      <li>
        <button type="button" class="group flex w-full items-start gap-2.5 rounded-xl p-2 text-left"
          data-action="page-tools#openExternal" data-page-tools-provider-param="chatgpt">
          <span
            class="flex size-9 shrink-0 items-center justify-center rounded-xl border border-base-300 bg-base-100 text-base-content/50 transition-colors group-hover:text-base-content/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"
              fill-rule="evenodd">
              <path
                d="M21.55 10.004a5.416 5.416 0 00-.478-4.501c-1.217-2.09-3.662-3.166-6.05-2.66A5.59 5.59 0 0010.831 1C8.39.995 6.224 2.546 5.473 4.838A5.553 5.553 0 001.76 7.496a5.487 5.487 0 00.691 6.5 5.416 5.416 0 00.477 4.502c1.217 2.09 3.662 3.165 6.05 2.66A5.586 5.586 0 0013.168 23c2.443.006 4.61-1.546 5.361-3.84a5.553 5.553 0 003.715-2.66 5.488 5.488 0 00-.693-6.497v.001zm-8.381 11.558a4.199 4.199 0 01-2.675-.954c.034-.018.093-.05.132-.074l4.44-2.53a.71.71 0 00.364-.623v-6.176l1.877 1.069c.02.01.033.029.036.05v5.115c-.003 2.274-1.87 4.118-4.174 4.123zM4.192 17.78a4.059 4.059 0 01-.498-2.763c.032.02.09.055.131.078l4.44 2.53c.225.13.504.13.73 0l5.42-3.088v2.138a.068.068 0 01-.027.057L9.9 19.288c-1.999 1.136-4.552.46-5.707-1.51h-.001zM3.023 8.216A4.15 4.15 0 015.198 6.41l-.002.151v5.06a.711.711 0 00.364.624l5.42 3.087-1.876 1.07a.067.067 0 01-.063.005l-4.489-2.559c-1.995-1.14-2.679-3.658-1.53-5.63h.001zm15.417 3.54l-5.42-3.088L14.896 7.6a.067.067 0 01.063-.006l4.489 2.557c1.998 1.14 2.683 3.662 1.529 5.633a4.163 4.163 0 01-2.174 1.807V12.38a.71.71 0 00-.363-.623zm1.867-2.773a6.04 6.04 0 00-.132-.078l-4.44-2.53a.731.731 0 00-.729 0l-5.42 3.088V7.325a.068.068 0 01.027-.057L14.1 4.713c2-1.137 4.555-.46 5.707 1.513.487.833.664 1.809.499 2.757h.001zm-11.741 3.81l-1.877-1.068a.065.065 0 01-.036-.051V6.559c.001-2.277 1.873-4.122 4.181-4.12.976 0 1.92.338 2.671.954-.034.018-.092.05-.131.073l-4.44 2.53a.71.71 0 00-.365.623l-.003 6.173v.002zm1.02-2.168L12 9.25l2.414 1.375v2.75L12 14.75l-2.415-1.375v-2.75z">
              </path>
            </svg>
          </span>
          <span class="flex min-w-0 flex-1 flex-col">
            <span class="inline-flex items-center gap-1 font-semibold leading-tight">
              {{ 'snippets.page_tools.open_in_chatgpt' | t }}
              <svg xmlns="http://www.w3.org/2000/svg"
                class="size-3 text-base-content/60 transition-colors group-hover:text-base-content/80"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h9v9"></path>
              </svg>
            </span>
            <span class="mt-0.5 text-xs text-base-content/60 leading-tight">{{ 'snippets.page_tools.ask_about_page' | t }}</span>
          </span>
        </button>
      </li>
      <li>
        <button type="button" class="group flex w-full items-start gap-2.5 rounded-xl p-2 text-left"
          data-action="page-tools#openExternal" data-page-tools-provider-param="claude">
          <span
            class="flex size-9 shrink-0 items-center justify-center rounded-xl border border-base-300 bg-base-100 text-base-content/50 transition-colors group-hover:text-base-content/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0" viewBox="0 0 256 257" fill="currentColor"
              fill-rule="evenodd" preserveAspectRatio="xMidYMid">
              <path
