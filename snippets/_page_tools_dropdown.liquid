              </path>
            </svg>
          </span>
          <span class="flex min-w-0 flex-1 flex-col">
            <span class="inline-flex items-center gap-1 font-semibold leading-tight">
              {{ 'snippets.page_tools.open_in_claude' | t }}
              <svg xmlns="http://www.w3.org/2000/svg"
                class="size-3 text-base-content/60 transition-colors group-hover:text-base-content/80"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h9v9"></path>
              </svg>
            </span>
            <span class="mt-0.5 text-xs text-base-content/60 leading-tight">{{ 'snippets.page_tools.ask_about_page' | t }}</span>
          </span>
        </button>
      </li>
      <li>
        <button type="button" class="group flex items-start gap-2.5 rounded-xl p-2 text-left"
          data-action="page-tools#copyMcpCommand">
          <span
            class="flex size-9 shrink-0 items-center justify-center rounded-xl border border-base-300 bg-base-100 text-base-content/50 transition-colors group-hover:text-base-content/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <rect x="3" y="4" width="18" height="16" rx="2"></rect>
              <path d="m9 10 2 2-2 2M13 14h3"></path>
            </svg>
          </span>
          <span class="flex min-w-0 flex-1 flex-col">
            <span class="font-semibold leading-tight">{{ 'snippets.page_tools.copy_mcp_label' | t }}</span>
            <span class="mt-0.5 text-xs text-base-content/60 leading-tight">{{ 'snippets.page_tools.copy_mcp_description' | t }}</span>
          </span>
        </button>
      </li>
      <li>
        <button type="button" class="group flex w-full items-start gap-2.5 rounded-xl p-2 text-left"
          data-action="page-tools#openExternal" data-page-tools-provider-param="cursor">
          <span
            class="flex size-9 shrink-0 items-center justify-center rounded-xl border border-base-300 bg-base-100 text-base-content/50 transition-colors group-hover:text-base-content/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0" viewBox="0 0 16 16" fill="none">
              <path
                d="M14.4734 3.9527L8.31773 0.398522C8.22052 0.342485 8.11029 0.312988 7.99809 0.312988C7.88589 0.312988 7.77566 0.342485 7.67846 0.398522L1.52355 3.9527C1.44182 3.99989 1.37394 4.06773 1.32671 4.14942C1.27948 4.23112 1.25457 4.32379 1.25446 4.41816V11.584C1.25457 11.6783 1.27948 11.771 1.32671 11.8527C1.37394 11.9344 1.44182 12.0022 1.52355 12.0494L7.67918 15.6036C7.77636 15.6597 7.8866 15.6893 7.99882 15.6893C8.11103 15.6893 8.22127 15.6597 8.31846 15.6036L14.4741 12.0502C14.5558 12.003 14.6237 11.9351 14.6709 11.8534C14.7182 11.7717 14.7431 11.6791 14.7432 11.5847V4.41743C14.7431 4.32307 14.7182 4.23039 14.6709 4.14869C14.6237 4.067 14.5558 3.99916 14.4741 3.95198L14.4734 3.9527ZM14.0872 4.70543L8.14464 14.9978C8.10464 15.0669 7.99846 15.0385 7.99846 14.9578V8.21889C7.99841 8.15254 7.98092 8.08738 7.94773 8.02993C7.91454 7.97249 7.86682 7.92478 7.80936 7.89161L1.97373 4.52361C1.90391 4.48289 1.93227 4.3767 2.013 4.3767H13.8966C14.0661 4.3767 14.1715 4.55925 14.0872 4.70543Z"
                fill="currentColor"></path>
            </svg>
          </span>
          <span class="flex min-w-0 flex-1 flex-col">
            <span class="inline-flex items-center gap-1 font-semibold leading-tight">
              {{ 'snippets.page_tools.connect_to_cursor' | t }}
              <svg xmlns="http://www.w3.org/2000/svg"
                class="size-3 text-base-content/60 transition-colors group-hover:text-base-content/80"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h9v9"></path>
              </svg>
            </span>
            <span class="mt-0.5 text-xs text-base-content/60 leading-tight">{{ 'snippets.page_tools.connect_to_cursor_description' | t }}</span>
          </span>
        </button>
      </li>
      <li>
        <button type="button" class="group flex w-full items-start gap-2.5 rounded-xl p-2 text-left"
          data-action="page-tools#openExternal" data-page-tools-provider-param="vscode">
          <span
            class="flex size-9 shrink-0 items-center justify-center rounded-xl border border-base-300 bg-base-100 text-base-content/50 transition-colors group-hover:text-base-content/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0" viewBox="0 0 100 100" fill="currentColor">
              <path fill-rule="evenodd" clip-rule="evenodd"
                d="M70.9119 99.3171C72.4869 99.9307 74.2828 99.8914 75.8725 99.1264L96.4608 89.2197C98.6242 88.1787 100 85.9892 100 83.5872V16.4133C100 14.0113 98.6243 11.8218 96.4609 10.7808L75.8725 0.873756C73.7862 -0.130129 71.3446 0.11576 69.5135 1.44695C69.252 1.63711 69.0028 1.84943 68.769 2.08341L29.3551 38.0415L12.1872 25.0096C10.589 23.7965 8.35363 23.8959 6.86933 25.2461L1.36303 30.2549C-0.452552 31.9064 -0.454633 34.7627 1.35853 36.417L16.2471 50.0001L1.35853 63.5832C-0.454633 65.2374 -0.452552 68.0938 1.36303 69.7453L6.86933 74.7541C8.35363 76.1043 10.589 76.2037 12.1872 74.9905L29.3551 61.9587L68.769 97.9167C69.3925 98.5406 70.1246 99.0104 70.9119 99.3171ZM75.0152 27.2989L45.1091 50.0001L75.0152 72.7012V27.2989Z">
              </path>
            </svg>
          </span>
          <span class="flex min-w-0 flex-1 flex-col">
            <span class="inline-flex items-center gap-1 font-semibold leading-tight">
              {{ 'snippets.page_tools.connect_to_vscode' | t }}
              <svg xmlns="http://www.w3.org/2000/svg"
                class="size-3 text-base-content/60 transition-colors group-hover:text-base-content/80"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h9v9"></path>
              </svg>
            </span>
            <span class="mt-0.5 text-xs text-base-content/60 leading-tight">{{ 'snippets.page_tools.connect_to_vscode_description' | t }}</span>
          </span>
        </button>
      </li>
    </ul>
  </div>
</div>