<!DOCTYPE html>
<html class="scroll-smooth" lang="{{ site.language }}" data-theme="baklib">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="author" content="Baklib">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Brand Guidelines · {{ site.name }}</title>
    {% meta_tags %}
    {{ 'stylesheets/application.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.js' | asset_url | script_tag: data-turbo-track: 'reload' }}
    {{ 'javascripts/application.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
    {% if false %} {{ 'javascripts/cdn.tailwindcss.js' | asset_url | script_tag: data-turbo-track: 'reload' }} {% endif %}

    <style>
      /* === Baklib brand tokens (kept in sync with the brand_defaults_css capture above) === */
      [data-theme="baklib"] {
        color-scheme: light;

        --color-base-100: #f7f5f3;
        --color-base-200: oklch(95% 0.0081 61.42);
        --color-base-300: oklch(90% 0.0081 61.42);
        --color-base-content: oklch(40% 0.0081 61.42);

        --color-primary: #0f766e;
        --color-primary-content: #f7f5f3;
        --color-secondary: #c2410c;
        --color-secondary-content: oklch(73.92% 0.2135 50.94);
        --color-accent: #0f172a;
        --color-accent-content: oklch(98% 0.003 247.858);
        --color-neutral: oklch(90% 0.0081 61.42);
        --color-neutral-content: oklch(40% 0.0081 61.42);

        --color-info: oklch(80.39% 0.1148 241.68);
        --color-info-content: oklch(30.39% 0.1148 241.68);
        --color-success: #14b8a6;
        --color-success-content: oklch(23.92% 0.0901 136.87);
        --color-warning: #fdba74;
        --color-warning-content: oklch(43.92% 0.1085 80);
        --color-error: oklch(63% 0.237 25.331);
        --color-error-content: oklch(35.1% 0.1814 22.37);

        --radius-selector: 2rem;
        --radius-field: 0.5rem;
        --radius-box: 1rem;
        --size-selector: 0.25rem;
        --size-field: 0.25rem;
        --border: 2px;
        --depth: 1;
        --noise: 0;
      }

      .brand-swatch {
        aspect-ratio: 16 / 9;
        border-radius: var(--radius-box);
        border: 1px solid color-mix(in oklab, currentColor 12%, transparent);
      }
      .brand-section-anchor { scroll-margin-top: 5rem; }
    </style>
  </head>

  <body class="min-h-screen bg-base-100 text-base-content antialiased">
    {%- assign nav_links = "tokens,colors,radius,size,effects,typography,components,source" | split: "," -%}

    {% comment %} Top bar {% endcomment %}
    <header class="sticky top-0 z-20 border-b border-base-300/70 bg-base-100/85 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
        <a href="{{ site.index_path }}" class="flex items-center gap-2 text-sm font-semibold tracking-tight text-accent">
          <span class="inline-flex size-7 items-center justify-center rounded-box bg-primary text-primary-content">
            {% render 'icon', name: 'layers', class: 'size-4' %}
          </span>
          {{ site.name }} · Brand
        </a>
        <nav class="hidden items-center gap-1 text-sm md:flex">
          {%- for link in nav_links -%}
            <a href="#{{ link }}" class="rounded-field px-3 py-1.5 capitalize text-base-content/70 hover:bg-base-200 hover:text-base-content">{{ link }}</a>
          {%- endfor -%}
        </nav>
        <a href="#source" class="btn btn-primary btn-sm">Copy CSS</a>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 pb-24 sm:px-6">

      {% comment %} Hero {% endcomment %}
      <section class="py-12 sm:py-16">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="inline-flex items-center gap-2 rounded-selector bg-base-200 px-3 py-1 text-xs font-medium uppercase tracking-wider text-base-content/60">
              <span class="size-1.5 rounded-full bg-success"></span>
              daisyUI v5 · theme = baklib
            </p>
            <h1 class="mt-4 text-3xl font-semibold tracking-tight text-accent sm:text-5xl">
              Baklib Brand Guidelines
            </h1>
            <p class="mt-3 max-w-2xl text-base text-base-content/70">
              The single source of truth for this theme's visual system
              (<code class="rounded bg-base-200 px-1.5 py-0.5 text-sm text-accent">wiki/help</code>):
              colors, radius, sizing, and components all derive from this page.
              When updating any token, keep this page in sync with
              <code class="rounded bg-base-200 px-1.5 py-0.5 text-sm text-accent">src/stylesheets/application.css</code>.
            </p>
          </div>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4 md:max-w-md">
            <div class="rounded-box border border-base-300 bg-base-100 p-3">
              <p class="text-[11px] uppercase tracking-wider text-base-content/50">name</p>
              <p class="mt-1 font-mono text-sm text-accent">baklib</p>
            </div>
            <div class="rounded-box border border-base-300 bg-base-100 p-3">
              <p class="text-[11px] uppercase tracking-wider text-base-content/50">scheme</p>
              <p class="mt-1 font-mono text-sm text-accent">light</p>
            </div>
            <div class="rounded-box border border-base-300 bg-base-100 p-3">
              <p class="text-[11px] uppercase tracking-wider text-base-content/50">default</p>
              <p class="mt-1 font-mono text-sm text-accent">false</p>
            </div>
            <div class="rounded-box border border-base-300 bg-base-100 p-3">
              <p class="text-[11px] uppercase tracking-wider text-base-content/50">prefersdark</p>
              <p class="mt-1 font-mono text-sm text-accent">false</p>
            </div>
          </div>
        </div>
      </section>

      {% comment %} Tokens overview {% endcomment %}
      <section id="tokens" class="brand-section-anchor border-t border-base-300 py-12">
        <h2 class="text-xl font-semibold tracking-tight text-accent">Design Tokens</h2>
        <p class="mt-1 text-sm text-base-content/60">Six categories form a complete daisyUI theme. Colors suffixed with <code>-content</code> guarantee text contrast on their corresponding background.</p>
        <div class="mt-6 grid gap-3 sm:grid-cols-3 lg:grid-cols-6">
          {%- assign token_groups = "Color,Radius,Size,Border,Depth,Noise" | split: "," -%}
          {%- assign token_values = "8 pairs,3 levels,2 levels,2px,1,0" | split: "," -%}
          {%- for g in token_groups -%}
            <div class="rounded-box border border-base-300 bg-base-100 p-4">
              <p class="text-[11px] uppercase tracking-wider text-base-content/50">{{ g }}</p>
              <p class="mt-2 font-mono text-base text-accent">{{ token_values[forloop.index0] }}</p>
            </div>
          {%- endfor -%}
        </div>
      </section>

      {% comment %} Colors {% endcomment %}
      <section id="colors" class="brand-section-anchor border-t border-base-300 py-12">
        <div class="flex items-end justify-between">
          <div>
            <h2 class="text-xl font-semibold tracking-tight text-accent">Color Palette</h2>
            <p class="mt-1 text-sm text-base-content/60">All colors are exposed as CSS variables. Use them directly via Tailwind classes such as <code>bg-primary</code> or <code>text-primary-content</code>.</p>
          </div>
        </div>

        {% comment %} Base / surface colors {% endcomment %}
        <h3 class="mt-8 text-sm font-semibold uppercase tracking-wider text-base-content/60">Base / Surface</h3>
        <div class="mt-3 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {%- assign base_keys = "base-100,base-200,base-300,base-content" | split: "," -%}
          {%- assign base_vals = "#f7f5f3,oklch(95% 0.0081 61.42),oklch(90% 0.0081 61.42),oklch(40% 0.0081 61.42)" | split: "," -%}
          {%- for k in base_keys -%}
            <figure class="overflow-hidden rounded-box border border-base-300 bg-base-100">
              <div class="brand-swatch !rounded-none !border-0" style="background-color: var(--color-{{ k }})"></div>
              <figcaption class="flex items-center justify-between gap-2 px-4 py-3 text-xs">
                <span class="font-medium text-accent">{{ k }}</span>
                <code class="truncate font-mono text-[11px] text-base-content/60">{{ base_vals[forloop.index0] }}</code>
              </figcaption>
            </figure>
          {%- endfor -%}
        </div>

        {% comment %} Brand / semantic palette (with content pairs) {% endcomment %}
        <h3 class="mt-10 text-sm font-semibold uppercase tracking-wider text-base-content/60">Brand · Semantic</h3>
        <div class="mt-3 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {%- assign brand_keys  = "primary,secondary,accent,neutral,info,success,warning,error" | split: "," -%}
          {%- assign brand_vals  = "#0f766e,#c2410c,#0f172a,oklch(21% 0.034 264.665),oklch(80.39% 0.1148 241.68),#14b8a6,#fdba74,oklch(63% 0.237 25.331)" | split: "," -%}
          {%- assign brand_cvals = "#f7f5f3,oklch(73.92% 0.2135 50.94),oklch(98% 0.003 247.858),#f7f5f3,oklch(30.39% 0.1148 241.68),oklch(23.92% 0.0901 136.87),oklch(43.92% 0.1085 80),oklch(35.1% 0.1814 22.37)" | split: "," -%}
          {%- for k in brand_keys -%}
            <figure class="overflow-hidden rounded-box border border-base-300 bg-base-100">
              <div class="flex h-28 items-center justify-center" style="background-color: var(--color-{{ k }}); color: var(--color-{{ k }}-content)">
                <span class="text-sm font-medium">{{ k | capitalize }} / content</span>
              </div>
              <figcaption class="grid grid-cols-2 gap-2 px-4 py-3 text-[11px]">
                <div>
                  <p class="font-medium text-accent">{{ k }}</p>
                  <code class="font-mono text-base-content/60 truncate block">{{ brand_vals[forloop.index0] }}</code>
                </div>
                <div>
                  <p class="font-medium text-accent">{{ k }}-content</p>
                  <code class="font-mono text-base-content/60 truncate block">{{ brand_cvals[forloop.index0] }}</code>
                </div>
              </figcaption>
            </figure>
          {%- endfor -%}
        </div>
      </section>

      {% comment %} Radius {% endcomment %}
      <section id="radius" class="brand-section-anchor border-t border-base-300 py-12">
        <h2 class="text-xl font-semibold tracking-tight text-accent">Border Radius</h2>
        <p class="mt-1 text-sm text-base-content/60">Three radius tokens, picked by semantic role: selector (extra round) → field (gentle) → box (strong).</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-3">
          {%- assign radius_keys = "selector,field,box" | split: "," -%}
          {%- assign radius_vals = "2rem,0.5rem,1rem" | split: "," -%}
          {%- assign radius_use  = "Badge / Toggle / Checkbox,Button / Input / Tab,Card / Modal / Alert" | split: "," -%}
          {%- for k in radius_keys -%}
            <div class="rounded-box border border-base-300 bg-base-100 p-5">
              <div class="flex items-center justify-between">
                <p class="font-mono text-sm text-accent">--radius-{{ k }}</p>
                <code class="text-xs text-base-content/60">{{ radius_vals[forloop.index0] }}</code>
              </div>
              <div class="mt-4 flex h-24 items-center justify-center bg-primary/10" style="border-radius: var(--radius-{{ k }})">
                <div class="size-14 bg-primary" style="border-radius: var(--radius-{{ k }})"></div>
              </div>
              <p class="mt-3 text-xs text-base-content/60">Used for: {{ radius_use[forloop.index0] }}</p>
            </div>
          {%- endfor -%}
        </div>
      </section>

      {% comment %} Sizes {% endcomment %}
      <section id="size" class="brand-section-anchor border-t border-base-300 py-12">
        <h2 class="text-xl font-semibold tracking-tight text-accent">Sizing</h2>
        <p class="mt-1 text-sm text-base-content/60">Base unit for sizing; daisyUI derives the xs / sm / md / lg / xl scale from it.</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-box border border-base-300 bg-base-100 p-5">
            <div class="flex items-center justify-between">
              <p class="font-mono text-sm text-accent">--size-field</p>
              <code class="text-xs text-base-content/60">0.25rem</code>
            </div>
            <div class="mt-4 flex items-end gap-2">
              <button class="btn btn-xs btn-primary">xs</button>
              <button class="btn btn-sm btn-primary">sm</button>
              <button class="btn btn-md btn-primary">md</button>
              <button class="btn btn-lg btn-primary">lg</button>
            </div>
          </div>
          <div class="rounded-box border border-base-300 bg-base-100 p-5">
            <div class="flex items-center justify-between">
              <p class="font-mono text-sm text-accent">--size-selector</p>
              <code class="text-xs text-base-content/60">0.25rem</code>
            </div>
            <div class="mt-4 flex items-center gap-3">
              <input type="checkbox" checked class="checkbox checkbox-xs checkbox-primary"/>
              <input type="checkbox" checked class="checkbox checkbox-sm checkbox-primary"/>
              <input type="checkbox" checked class="checkbox checkbox-md checkbox-primary"/>
              <input type="checkbox" checked class="checkbox checkbox-lg checkbox-primary"/>
              <input type="checkbox" checked class="toggle toggle-primary"/>
            </div>
          </div>
        </div>
      </section>

      {% comment %} Effects {% endcomment %}
      <section id="effects" class="brand-section-anchor border-t border-base-300 py-12">
        <h2 class="text-xl font-semibold tracking-tight text-accent">Effects</h2>
        <p class="mt-1 text-sm text-base-content/60">Border width / depth / noise — three knobs that shape the overall tactile feel of the brand.</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-3">
          <div class="rounded-box border border-base-300 bg-base-100 p-5">
            <p class="font-mono text-sm text-accent">--border</p>
            <p class="mt-1 text-xs text-base-content/60">2px · thicker, reinforces geometric edges</p>
            <button class="btn btn-outline btn-primary mt-4 w-full">Outline Button</button>
          </div>
          <div class="rounded-box border border-base-300 bg-base-100 p-5">
            <p class="font-mono text-sm text-accent">--depth</p>
            <p class="mt-1 text-xs text-base-content/60">1 · enables 3D shadows and highlights</p>
            <button class="btn btn-primary mt-4 w-full">Solid Button</button>
          </div>
          <div class="rounded-box border border-base-300 bg-base-100 p-5">
            <p class="font-mono text-sm text-accent">--noise</p>
            <p class="mt-1 text-xs text-base-content/60">0 · noise disabled, surfaces stay clean</p>
            <div class="mt-4 h-10 rounded-field bg-primary"></div>
          </div>
        </div>
      </section>

      {% comment %} Typography {% endcomment %}
      <section id="typography" class="brand-section-anchor border-t border-base-300 py-12">
        <h2 class="text-xl font-semibold tracking-tight text-accent">Typography</h2>
        <p class="mt-1 text-sm text-base-content/60">Fonts follow the system default sans-serif stack. Headings use <code>tracking-tight</code> + <code>text-accent</code>; body text uses <code>text-base-content</code>.</p>
        <div class="mt-6 space-y-4 rounded-box border border-base-300 bg-base-100 p-6">
          <div>
            <p class="text-xs uppercase tracking-wider text-base-content/50">Display · text-5xl / semibold</p>
            <p class="mt-1 text-5xl font-semibold tracking-tight text-accent">Let content flow</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wider text-base-content/50">H1 · text-3xl / semibold</p>
            <p class="mt-1 text-3xl font-semibold tracking-tight text-accent">Heading One</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wider text-base-content/50">H2 · text-xl / semibold</p>
            <p class="mt-1 text-xl font-semibold tracking-tight text-accent">Heading Two</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wider text-base-content/50">Body · text-base</p>
            <p class="mt-1 text-base text-base-content">Baklib is a lightweight CMS &amp; knowledge-base platform for teams, built on daisyUI v5.</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wider text-base-content/50">Caption · text-sm / muted</p>
            <p class="mt-1 text-sm text-base-content/60">Used for explanatory copy, form hints, and timestamps.</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wider text-base-content/50">Code · font-mono</p>
            <p class="mt-1 font-mono text-sm text-accent">npm run build · yarn dev</p>
          </div>
        </div>
      </section>

      {% comment %} Components {% endcomment %}
      <section id="components" class="brand-section-anchor border-t border-base-300 py-12">
        <h2 class="text-xl font-semibold tracking-tight text-accent">Components</h2>
        <p class="mt-1 text-sm text-base-content/60">Prefer daisyUI components first (<code>btn / input / card / alert / badge</code>); only customize when truly necessary.</p>

        {% comment %} Buttons {% endcomment %}
        <div class="mt-6 rounded-box border border-base-300 bg-base-100 p-6">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">Buttons</h3>
          <div class="mt-4 flex flex-wrap gap-3">
            <button class="btn btn-primary">Primary</button>
            <button class="btn btn-secondary">Secondary</button>
            <button class="btn btn-accent">Accent</button>
            <button class="btn btn-neutral">Neutral</button>
            <button class="btn btn-ghost">Ghost</button>
            <button class="btn btn-link">Link</button>
          </div>
          <div class="mt-4 flex flex-wrap gap-3">
            <button class="btn btn-outline btn-primary">Outline</button>
            <button class="btn btn-soft btn-primary">Soft</button>
            <button class="btn btn-dash btn-primary">Dash</button>
            <button class="btn btn-primary" disabled>Disabled</button>
            <button class="btn btn-primary">
              <span class="loading loading-spinner loading-xs"></span>
              Loading
            </button>
          </div>
        </div>

        {% comment %} Forms {% endcomment %}
        <div class="mt-4 rounded-box border border-base-300 bg-base-100 p-6">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">Form Controls</h3>
          <div class="mt-4 grid gap-4 md:grid-cols-2">
            <label class="form-control">
              <span class="label-text mb-1 text-xs text-base-content/60">Email</span>
              <input type="email" placeholder="you@baklib.com" class="input input-bordered w-full"/>
            </label>
            <label class="form-control">
              <span class="label-text mb-1 text-xs text-base-content/60">Select</span>
              <select class="select select-bordered w-full">
                <option>Option A</option>
                <option>Option B</option>
              </select>
            </label>
            <label class="form-control md:col-span-2">
              <span class="label-text mb-1 text-xs text-base-content/60">Textarea</span>
              <textarea class="textarea textarea-bordered" rows="3" placeholder="Say something..."></textarea>
            </label>
            <div class="flex flex-wrap items-center gap-4">
              <label class="flex items-center gap-2 text-sm"><input type="checkbox" checked class="checkbox checkbox-primary"/> Checkbox</label>
              <label class="flex items-center gap-2 text-sm"><input type="radio" name="r" checked class="radio radio-primary"/> Radio</label>
              <label class="flex items-center gap-2 text-sm"><input type="checkbox" checked class="toggle toggle-primary"/> Toggle</label>
            </div>
            <div>
              <input type="range" min="0" max="100" value="40" class="range range-primary range-sm"/>
            </div>
          </div>
        </div>

        {% comment %} Badges & Status {% endcomment %}
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          <div class="rounded-box border border-base-300 bg-base-100 p-6">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">Badges</h3>
            <div class="mt-4 flex flex-wrap gap-2">
              <span class="badge badge-primary">Primary</span>
              <span class="badge badge-secondary">Secondary</span>
              <span class="badge badge-accent">Accent</span>
              <span class="badge badge-info">Info</span>
              <span class="badge badge-success">Success</span>
              <span class="badge badge-warning">Warning</span>
              <span class="badge badge-error">Error</span>
              <span class="badge badge-outline">Outline</span>
            </div>
          </div>
          <div class="rounded-box border border-base-300 bg-base-100 p-6">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">Loading</h3>
            <div class="mt-4 flex items-center gap-4 text-primary">
              <span class="loading loading-spinner loading-md"></span>
              <span class="loading loading-dots loading-md"></span>
              <span class="loading loading-ring loading-md"></span>
              <span class="loading loading-ball loading-md"></span>
              <span class="loading loading-bars loading-md"></span>
            </div>
          </div>
        </div>

        {% comment %} Alerts {% endcomment %}
        <div class="mt-4 rounded-box border border-base-300 bg-base-100 p-6">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">Alerts</h3>
          <div class="mt-4 grid gap-3 md:grid-cols-2">
            <div role="alert" class="alert alert-info">
              {% render 'icon', name: 'info', class: 'h-5 w-5 shrink-0 stroke-current' %}
              <span>This is an informational message.</span>
            </div>
            <div role="alert" class="alert alert-success">
              {% render 'icon', name: 'circle-check', class: 'h-5 w-5 shrink-0 stroke-current' %}
              <span>Operation completed successfully.</span>
            </div>
            <div role="alert" class="alert alert-warning">
              {% render 'icon', name: 'triangle-alert', class: 'h-5 w-5 shrink-0 stroke-current' %}
              <span>Heads up — there is a potential risk here.</span>
            </div>
            <div role="alert" class="alert alert-error">
              {% render 'icon', name: 'circle-x', class: 'h-5 w-5 shrink-0 stroke-current' %}
              <span>Operation failed. Please try again later.</span>
            </div>
          </div>
        </div>

        {% comment %} Cards & Stats {% endcomment %}
        <div class="mt-4 grid gap-4 md:grid-cols-3">
          <div class="card border border-base-300 bg-base-100 shadow-sm md:col-span-2">
            <div class="card-body">
              <h3 class="card-title text-accent">Card title</h3>
              <p class="text-sm text-base-content/70">Built on daisyUI's <code>card</code> container; its corner radius automatically follows <code>--radius-box</code>. Cards are the preferred container for composing complex information.</p>
              <div class="card-actions justify-end pt-2">
                <button class="btn btn-ghost btn-sm">Cancel</button>
                <button class="btn btn-primary btn-sm">Confirm</button>
              </div>
            </div>
          </div>
          <div class="stats stats-vertical border border-base-300 bg-base-100">
            <div class="stat">
              <div class="stat-title">Visits</div>
              <div class="stat-value text-primary">31K</div>
              <div class="stat-desc">↑ 12% vs last week</div>
            </div>
            <div class="stat">
              <div class="stat-title">Articles</div>
              <div class="stat-value text-accent">128</div>
              <div class="stat-desc">+14 this month</div>
            </div>
          </div>
        </div>

        {% comment %} Tabs {% endcomment %}
        <div class="mt-4 rounded-box border border-base-300 bg-base-100 p-6">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">Tabs</h3>
          <div role="tablist" class="tabs tabs-bordered mt-4">
            <a role="tab" class="tab">Overview</a>
            <a role="tab" class="tab tab-active">Design</a>
            <a role="tab" class="tab">Code</a>
          </div>
        </div>
      </section>

      {% comment %} Integration {% endcomment %}
      <section id="source" class="brand-section-anchor border-t border-base-300 py-12">
        <div class="flex items-end justify-between">
          <div>
            <h2 class="text-xl font-semibold tracking-tight text-accent">Integration</h2>
            <p class="mt-1 max-w-2xl text-sm text-base-content/60">
              Baklib CMS themes support real-time color customization from the admin panel, so
              <strong>colors</strong> and <strong>static tokens</strong> take different entry points.
              Do <em>not</em> put <code class="rounded bg-base-200 px-1.5 py-0.5 text-accent">@plugin "daisyui/theme"</code>
              directly into <code>application.css</code> — that bypasses the platform's runtime
              customization mechanism.
            </p>
          </div>
          <a href="#tokens" class="btn btn-ghost btn-sm">Back to top ↑</a>
        </div>

        {% comment %} Architecture diagram {% endcomment %}
        <div class="mt-6 rounded-box border border-base-300 bg-base-200/40 p-5">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">Runtime customization flow</h3>
          <ol class="mt-3 grid gap-3 text-sm text-base-content/80 md:grid-cols-4">
            <li class="rounded-field border border-base-300 bg-base-100 p-3">
              <span class="badge badge-primary badge-sm">1</span>
              <p class="mt-2 font-medium text-accent">Admin panel</p>
              <p class="mt-1 text-xs text-base-content/60">User picks a recommended palette or custom HEX colors</p>
            </li>
            <li class="rounded-field border border-base-300 bg-base-100 p-3">
              <span class="badge badge-primary badge-sm">2</span>
              <p class="mt-2 font-medium text-accent">Platform inject</p>
              <p class="mt-1 text-xs text-base-content/60">Each color is split into HSL components and written to <code>:root --theme-color-*</code></p>
            </li>
            <li class="rounded-field border border-base-300 bg-base-100 p-3">
              <span class="badge badge-primary badge-sm">3</span>
              <p class="mt-2 font-medium text-accent">Layout mapping</p>
              <p class="mt-1 text-xs text-base-content/60"><code>layout/theme.liquid</code> maps <code>--theme-color-*</code> onto daisyUI's <code>--color-*</code></p>
            </li>
            <li class="rounded-field border border-base-300 bg-base-100 p-3">
              <span class="badge badge-primary badge-sm">4</span>
              <p class="mt-2 font-medium text-accent">Instant apply</p>
              <p class="mt-1 text-xs text-base-content/60">All daisyUI components refresh immediately — no CSS rebuild needed</p>
            </li>
          </ol>
        </div>

        {% comment %} Snippet A: static tokens {% endcomment %}
        <div class="mt-8">
          <div class="flex items-center justify-between">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">A · Static tokens</h3>
            <code class="text-xs text-base-content/60">src/stylesheets/application.css</code>
          </div>
          <p class="mt-1 text-xs text-base-content/60">Radius / size / border / depth / noise — these are fixed brand properties, not exposed to admin customization.</p>
          <pre class="mt-3 overflow-x-auto rounded-box border border-base-300 bg-accent p-5 text-xs leading-relaxed text-accent-content"><code>{{ brand_static_tokens_css }}</code></pre>
        </div>

        {% comment %} Snippet B: runtime color mapping {% endcomment %}
        <div class="mt-6">
          <div class="flex items-center justify-between">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">B · Runtime color mapping</h3>
            <code class="text-xs text-base-content/60">layout/theme.liquid &amp; layout/error.liquid</code>
          </div>
          <p class="mt-1 text-xs text-base-content/60">Inject a <code>&lt;style&gt;</code> in <code>&lt;head&gt;</code> to map platform-provided <code>--theme-color-*</code> onto daisyUI's <code>--color-*</code>, enabling real-time customization.</p>
          <pre class="mt-3 overflow-x-auto rounded-box border border-base-300 bg-accent p-5 text-xs leading-relaxed text-accent-content"><code>{{ brand_runtime_mapping_css }}</code></pre>
        </div>

        {% comment %} Snippet C: schema preset {% endcomment %}
        <div class="mt-6">
          <div class="flex items-center justify-between">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">C · Recommended palette (admin-selectable)</h3>
            <code class="text-xs text-base-content/60">config/settings_schema.json</code>
          </div>
          <p class="mt-1 text-xs text-base-content/60">Register the "baklib brand" preset under <code>theme_info.recommendations.color_schemas</code>, paired with the locale key <code>schema.recommendations.baklib.name</code>.</p>
          <pre class="mt-3 overflow-x-auto rounded-box border border-base-300 bg-accent p-5 text-xs leading-relaxed text-accent-content"><code>{{ brand_schema_json }}</code></pre>
        </div>

        {% comment %} Snippet D: full brand reference {% endcomment %}
        <details class="mt-8 rounded-box border border-base-300 bg-base-100">
          <summary class="cursor-pointer px-5 py-3 text-sm font-medium text-accent">
            D · Full brand defaults (developer reference only)
          </summary>
          <div class="border-t border-base-300 p-5">
            <p class="text-xs text-base-content/60">Below are the expected default values for every brand token. This page inlines them under <code>[data-theme="baklib"]</code> to demonstrate the brand effect; in production the actual colors come from the combination of A + B + C above.</p>
            <pre class="mt-3 overflow-x-auto rounded-box border border-base-300 bg-accent p-5 text-xs leading-relaxed text-accent-content"><code>{{ brand_defaults_css }}</code></pre>
          </div>
        </details>
      </section>

      <footer class="mt-12 border-t border-base-300 pt-6 text-center text-xs text-base-content/50">
        Baklib · wiki/help · Brand Guidelines · Read the file header comment before editing this page.
      </footer>
    </main>
  </body>
</html>
